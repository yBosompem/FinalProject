{
  "name": "secure-exam-monitor",
  "version": "1.0.0",
  "private": true,
  "description": "AI-assisted secure online examination monitoring system",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "seed": "npm run seed --prefix server",
    "ai": "cd ai-service && python -m uvicorn app:app --reload --host 0.0.0.0 --port 8000",
    "ai:train": "cd ai-service && python train.py",
    "ai:train:coco8": "cd ai-service && python train.py --data data/coco8.yaml --epochs 100 --imgsz 640"
  },
  "dependencies": {
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow-models/face-landmarks-detection": "^1.0.6",
    "@tensorflow-models/mobilenet": "^2.1.1",
    "face-api.js": "^0.20.0"
  }
}
